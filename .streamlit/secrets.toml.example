# Streamlit Community Cloud — Secrets 템플릿
#
# 로컬에서는 .env 파일을 쓰고, 클라우드에서는 본 파일과 같은 형식으로
# share.streamlit.io → 앱 설정 → Secrets 칸에 그대로 붙여넣습니다.
#
# ⚠️ 실제 키가 들어간 secrets.toml 은 절대 커밋하지 마세요. (.gitignore 처리됨)

# Anthropic Claude API 키 (필수)
ANTHROPIC_API_KEY = "sk-ant-...본인키..."

# 앱 비밀번호 (선택)
#   - 값이 있으면 로그인 게이트가 켜지고, 비우거나 키를 삭제하면 게이트가 꺼집니다.
#   - 시연·심사위원 공유 시 간단한 보호 용도로만 쓰세요 (강도 높은 인증 아님).
APP_PASSWORD = "원하는-비밀번호"
