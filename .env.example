# 사초 AI 시범 데모 — 환경변수 템플릿
# 사용법:
#   1) 이 파일을 .env 로 복사
#   2) 아래 키 값들을 실제 키로 채워 넣기
#
# console.anthropic.com → API Keys 에서 발급

ANTHROPIC_API_KEY=sk-ant-...여기에-본인-키를-붙여넣기...

# (선택) 공공데이터포털 사료 다운로드용 API 키
# https://www.data.go.kr → 활용신청 → 인증키
DATA_GO_KR_API_KEY=

# (선택) 임베딩 모드 활성화 (기본은 키워드 검색)
ENABLE_EMBEDDING=false
